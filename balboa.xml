<mujoco model="balboa_lab">
  <compiler angle="degree" coordinate="local" inertiafromgeom="false"/>
  <option timestep="0.002" gravity="0 0 -9.81" integrator="RK4"/>

  <default>
    <geom friction="0.8 0.005 0.0001" margin="0.001"/>
    <joint damping="0.0"/> 
  </default>

  <worldbody>
    <light directional="true" diffuse="0.8 0.8 0.8" pos="0 0 10" dir="0 0 -1"/>
    <geom name="floor" type="plane" size="2 2 0.1" rgba="0.2 0.2 0.2 1"/>

    <body name="balboa_base" pos="0 0 0.04"> 
      
      <freejoint name="root"/>
      
      <inertial pos="0 0 0.023" mass="0.316" diaginertia="444.43e-6 444.43e-6 444.43e-6"/>
      <geom name="body_geom" type="box" size="0.022 0.05 0.0545" pos="0 0 0.023" rgba="0 0.7 0 1"/>

      <body name="left_wheel" pos="0 0.05 0">
        <joint name="left_wheel_joint" type="hinge" axis="0 1 0"/>
        <inertial pos="0 0 0" mass="0.0021" diaginertia="13.445e-6 13.445e-6 13.445e-6"/>
        <geom name="wheel_l_geom" type="cylinder" size="0.04 0.005" euler="90 0 0" rgba="0.1 0.1 0.1 1"/>
      </body>

      <body name="right_wheel" pos="0 -0.05 0">
        <joint name="right_wheel_joint" type="hinge" axis="0 1 0"/>
        <inertial pos="0 0 0" mass="0.0021" diaginertia="13.445e-6 13.445e-6 13.445e-6"/>
        <geom name="wheel_r_geom" type="cylinder" size="0.04 0.005" euler="90 0 0" rgba="0.1 0.1 0.1 1"/>
      </body>
      
    </body>
  </worldbody>

  <actuator>
    <motor name="left_motor" joint="left_wheel_joint" ctrllimited="true" ctrlrange="-0.1 0.1"/>
    <motor name="right_motor" joint="right_wheel_joint" ctrllimited="true" ctrlrange="-0.1 0.1"/>
  </actuator>
</mujoco>
